{
  "name": "@ansvar-systems/dk-farm-safety-mcp",
  "version": "0.1.0",
  "description": "MCP server for Danish farm workplace safety \u2014 AT-vejledninger, APV, maskinsikkerhed",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "dk-farm-safety-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:http": "node dist/http-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "ingest": "tsx scripts/ingest.ts",
    "build:db": "tsx scripts/build-db.ts",
    "freshness:check": "tsx scripts/check-freshness.ts"
  },
  "keywords": [
    "mcp",
    "safety",
    "hse",
    "coshh",
    "riddor",
    "machinery",
    "farming"
  ],
  "author": "Ansvar Systems <info@ansvar.eu>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ansvar-Systems/dk-farm-safety-mcp.git"
  },
  "homepage": "https://ansvar.eu/open-agriculture",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.2.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
